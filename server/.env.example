# ── JWT ─────────────────────────────────────────────────────────────────────
# Must be >= 32 bytes (256 bits). Generate: node -e "require('crypto').randomBytes(64).toString('hex')|xargs echo"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MINIMUM_32_BYTES_NEVER_COMMIT

# Access token TTL in seconds (default 15 min)
JWT_ACCESS_EXPIRY=900

# Refresh token TTL in seconds (default 7 days)
JWT_REFRESH_EXPIRY=604800

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
# IMPORTANT: always bind to localhost; Nginx/API Gateway terminates TLS in production
HOST=127.0.0.1
NODE_ENV=development

# Number of trusted proxy hops (set to 1 when behind Nginx)
TRUST_PROXY=1

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ── Auth (bcrypt hashes — never store plain-text passwords) ──────────────────
# Generate: node -e "const b=require('bcryptjs');b.hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=
VIEWER_PASSWORD_HASH=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
